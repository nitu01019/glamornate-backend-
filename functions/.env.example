# Stripe — REMOVED (Phase 1 / Stripe removal, 2026-05-02). The platform is
# pay-at-spa only; online-payment env vars are no longer consumed.

# SendGrid (transactional email)
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=no-reply@glamornate.com
SENDGRID_FROM_NAME=Glamornate

# SMS via MSG91 Firebase Extension (msg91/msg91-send-msg)
# Install: firebase ext:install msg91/msg91-send-msg --project glamornate-758c6
# Configure: Auth Key (from MSG91 dashboard), collection = sms_dispatch, Sender ID = registered DLT sender
MSG91_COLLECTION_NAME=sms_dispatch

# Google Cloud
GCP_PROJECT_ID=glamornate-dev

# Tax & Platform Fee
TAX_RATE_PERCENT=18
PLATFORM_FEE_PERCENT=20

# Environment
NODE_ENV=development
