{
  "name": "firebase-functions",
  "version": "1.1.0",
  "description": "Glamornate Firebase Cloud Functions",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "deploy:api": "firebase deploy --only functions:api --project glamornate-758c6",
    "logs": "firebase functions:log",
    "lint": "eslint --ext .js,.ts src",
    "lint:fix": "eslint --ext .js,.ts src --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "seed:smoke": "ts-node --transpile-only ../scripts/seed-smoke-data.ts",
    "seed:catalog": "ts-node --transpile-only ../scripts/seed-services-from-catalog.ts",
    "verify:ttl": "ts-node --transpile-only scripts/verify-ttl-policies.ts",
    "test:emulator": "bash scripts/run-emulator-tests.sh"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "algoliasearch": "^4.20.0",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "date-fns-tz": "^3.2.0",
    "express": "^4.19.2",
    "firebase-admin": "^13",
    "firebase-functions": "^5.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^8.56.0",
    "firebase-functions-test": "^3.4.1",
    "googleapis": "^144.0.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "private": true
}
